# Seguridad de administración (OBLIGATORIO en producción)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Secreto de sesión para firmar cookies (mínimo 32 caracteres)
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# URL base del sitio (usada por webhooks y redirecciones)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# URL base opcional para servir assets (imagenes/videos/iconos) desde CDN o dominio estatico
# Ejemplo: https://cdn.cero.uno
NEXT_PUBLIC_ASSET_BASE_URL=

# Base de datos MySQL (Hostinger)
# Formato: mysql://usuario:contraseña@host:3306/nombre_base_datos
DATABASE_URL=
# Desactiva SSL si tu host MySQL no lo requiere (ej: conexión local en el mismo servidor)
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=10000

# Habilita lectura/escritura de inventario y multimedia en SQL
DB_PRODUCTS_ENABLED=false
DB_ASSET_STORAGE_ENABLED=false

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxx-xxxxxxxxx

# Facebook/Meta Pixel + Conversions API
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=
FACEBOOK_PIXEL_ID=
FACEBOOK_ACCESS_TOKEN=
# Opcional para pruebas en Event Manager
FACEBOOK_TEST_EVENT_CODE=

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Analytics 4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Pixel/Conversiones de Google Ads
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
