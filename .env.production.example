# Docker Environment Variables - CERO.UNO Production
# Copy to .env.production in your Hostinger server and replace values

NODE_ENV=production

# ===== ADMIN CREDENTIALS =====
# Change these to strong, unique values!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password-min-20-chars

# Generate with: openssl rand -base64 32
# This must be at least 32 characters for production
ADMIN_SESSION_SECRET=please-replace-with-output-from-openssl-rand-base64-32

# ===== OPTIONAL: API Configuration =====
# NEXT_PUBLIC_API_URL=https://cero.uno
# LOG_LEVEL=info
