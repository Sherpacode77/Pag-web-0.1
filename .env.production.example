# Docker Environment Variables - CERO.UNO Production
# Copy to .env.production in your Hostinger server and replace values

NODE_ENV=production

# ===== ADMIN CREDENTIALS =====
# Change these to strong, unique values!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password-min-20-chars

# Generate with: openssl rand -base64 32
# This must be at least 32 characters for production
ADMIN_SESSION_SECRET=please-replace-with-output-from-openssl-rand-base64-32

# ===== OPTIONAL: API Configuration =====
# NEXT_PUBLIC_API_URL=https://cero.uno
# LOG_LEVEL=info

# ===== BASE DE DATOS MySQL (Hostinger) =====
# Formato: mysql://usuario:contraseña@host:3306/nombre_base_datos
# En Hostinger el host suele ser localhost o un host interno del servidor
DATABASE_URL=mysql://usuario:contraseña@localhost:3306/nombre_base_datos
# En Hostinger la conexión es local — SSL generalmente no es necesario
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=10000
DB_PRODUCTS_ENABLED=true
DB_ASSET_STORAGE_ENABLED=true

# ===== SITE URL =====
NEXT_PUBLIC_SITE_URL=https://www.cero.uno
SITE_URL=https://www.cero.uno

# ===== MERCADO PAGO =====
# Access token privado de Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxx-xxxxxxxxx

# ===== EMAIL (Resend) =====
# API key de https://resend.com — plan gratuito alcanza para esto
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
# Remitente verificado en Resend (requiere dominio verificado por DNS)
RESEND_FROM_EMAIL=CERO.UNO <pedidos@cerounobikes.com>
# A dónde llega la notificación interna de "nuevo pedido pagado"
STORE_NOTIFICATION_EMAIL=tu-correo@ejemplo.com

# ===== META / FACEBOOK =====
# Pixel ID publico (cliente)
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=123456789012345
# Pixel ID servidor (puede ser el mismo)
FACEBOOK_PIXEL_ID=123456789012345
# Access token de Conversions API
FACEBOOK_ACCESS_TOKEN=EAAG...
# Opcional para modo test de eventos
# FACEBOOK_TEST_EVENT_CODE=TEST12345

# ===== GOOGLE TAG MANAGER =====
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ===== GOOGLE ANALYTICS 4 =====
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ===== GOOGLE ADS PIXEL =====
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
